@model Tarefa

@{
    ViewData["Title"] = "Nova Tarefa";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="mb-4">Nova Tarefa</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <h5 class="alert-heading">Erro ao criar tarefa</h5>
                    <ul class="mb-0">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post" action="@Url.Action("Create")">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label for="titulo" class="form-label">Título da Tarefa</label>
                    <input type="text" 
                           class="form-control @(ViewData.ModelState.ContainsKey("Titulo") && !ViewData.ModelState["Titulo"].ValidationState.ToString().Contains("Valid") ? "is-invalid" : "")" 
                           id="titulo" 
                           name="Titulo" 
                           placeholder="Digite o título da sua tarefa..."
                           maxlength="500"
                           value="@Model?.Titulo"
                           required 
                           autofocus />
                    <small class="form-text text-muted d-block mt-1">
                        Máximo de 500 caracteres
                    </small>
                    @if (ViewData.ModelState.ContainsKey("Titulo"))
                    {
                        <div class="invalid-feedback d-block">
                            @foreach (var error in ViewData.ModelState["Titulo"].Errors)
                            {
                                @error.ErrorMessage
                            }
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label for="descricao" class="form-label">Descrição (Opcional)</label>
                    <textarea class="form-control" 
                              id="descricao" 
                              name="Descricao" 
                              placeholder="Digite uma descrição detalhada para sua tarefa..."
                              rows="3"
                              maxlength="2000">@Model?.Descricao</textarea>
                    <small class="form-text text-muted d-block mt-1">
                        Máximo de 2000 caracteres
                    </small>
                </div>

                <div class="mb-3">
                    <label for="lembreteEm" class="form-label">Lembrete (Opcional)</label>
                    <input asp-for="LembreteEm" 
                           type="datetime-local" 
                           class="form-control" 
                           id="lembreteEm"
                           placeholder="Selecione data e hora do lembrete" />
                    <small class="form-text text-muted d-block mt-1">
                        Data e hora para seu lembrete
                    </small>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancelar</a>
                    <button type="submit" class="btn btn-success btn-lg">Criar Tarefa</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control {
        font-size: 1.1rem;
        padding: 0.75rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 1.05rem;
    }

    .btn-lg {
        font-size: 1rem;
        padding: 0.75rem 2rem;
    }

    @@media (max-width: 768px) {
        .d-md-flex {
            display: flex !important;
            flex-direction: column-reverse !important;
        }

        .col-md-8 {
            width: 100%;
        }

        .offset-md-2 {
            margin-left: 0;
        }

        .btn-lg {
            width: 100%;
            margin-bottom: 0.5rem;
        }
    }
</style>
