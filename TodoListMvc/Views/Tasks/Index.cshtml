@model List<Tarefa>

@{
    ViewData["Title"] = "Minhas Tarefas";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">Minhas Tarefas</h1>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Erro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-12">
            <a href="@Url.Action("Create")" class="btn btn-success btn-lg">
                <i class="bi bi-plus-circle"></i> Nova Tarefa
            </a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info mt-4" role="alert">
            <h5 class="alert-heading">Nenhuma tarefa cadastrada!</h5>
            <p>Comece clicando no botão "Nova Tarefa" acima para adicionar sua primeira tarefa.</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="list-group">
                    @foreach (var tarefa in Model)
                    {
                        <div class="list-group-item">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" 
                                               id="tarefa-@tarefa.Id" 
                                               @(tarefa.Concluida ? "checked" : "")
                                               onchange="document.getElementById('form-toggle-@tarefa.Id').submit();" />
                                        <label class="form-check-label @(tarefa.Concluida ? "text-decoration-line-through text-muted" : "")" 
                                               for="tarefa-@tarefa.Id">
                                            <strong>@tarefa.Titulo</strong>
                                        </label>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(tarefa.Descricao))
                                    {
                                        <div class="ms-4 mt-2 p-2 bg-light rounded">
                                            <small class="text-dark d-block">@tarefa.Descricao</small>
                                        </div>
                                    }
                                    @if (tarefa.LembreteEm.HasValue)
                                    {
                                        <div class="ms-4 mt-2 p-2 bg-warning bg-opacity-10 rounded">
                                            <small class="text-dark d-block">
                                                <strong>🔔 Lembrete:</strong> @tarefa.LembreteEm.Value.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                        </div>
                                    }
                                    <small class="text-muted d-block mt-1">
                                        Criada em: @tarefa.DataCriacao.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                                <div class="col-md-4 text-end">
                                    <div class="d-flex gap-2 justify-content-end mb-2">
                                        <a href="@Url.Action("Edit", new { id = tarefa.Id })" class="btn btn-sm btn-outline-info" title="Editar tarefa">
                                            ✎ Editar
                                        </a>
                                        <form method="post" 
                                              action="@Url.Action("Delete", new { id = tarefa.Id })" 
                                              style="display:inline;"
                                              onsubmit="return confirm('Tem certeza que deseja deletar esta tarefa?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                🗑️ Deletar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Hidden form for toggle complete -->
                        <form id="form-toggle-@tarefa.Id" 
                              method="post" 
                              action="@Url.Action("ToggleComplete", new { id = tarefa.Id })" 
                              style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .list-group-item {
        border-left: 4px solid #0d6efd;
        transition: all 0.3s ease;
    }

    .list-group-item:hover {
        background-color: #f8f9fa;
    }

    .form-check-input:checked ~ .form-check-label {
        color: #6c757d;
    }

    .badge {
        font-weight: 500;
        padding: 0.5rem 0.75rem;
    }

    .input-group-sm {
        max-width: 280px;
    }

    @@media (max-width: 768px) {
        .row {
            flex-wrap: wrap;
        }

        .col-md-8, .col-md-4 {
            width: 100%;
        }

        .col-md-4 {
            margin-top: 1rem;
            text-align: left;
        }

        .input-group-sm {
            max-width: 100%;
            margin-bottom: 0.5rem;
        }

        .btn-danger {
            width: 100%;
            margin-top: 0.5rem;
        }
    }
</style>
